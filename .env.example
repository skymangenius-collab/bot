# ============================================================
# ENVIRONMENT VARIABLES — Copy this to Railway's Variables tab
# ============================================================

# ✅ REQUIRED — Your Discord personal account token
# How to get it:
#   1. Open Discord in your browser (discord.com)
#   2. Press F12 → go to "Application" tab
#   3. Expand Local Storage → click https://discord.com
#   4. Find the key called "token" — copy the value (without quotes)
USER_TOKEN=paste_your_discord_token_here

# ✅ REQUIRED — Your free Groq API key
# How to get it:
#   1. Go to https://console.groq.com
#   2. Sign up / log in (free)
#   3. Click "API Keys" → "Create API Key"
#   4. Copy and paste it here
GROQ_API_KEY=paste_your_groq_api_key_here

# ✅ REQUIRED — The Discord channel ID to post in
# How to get it:
#   1. Enable Developer Mode in Discord (Settings → Advanced)
#   2. Right-click the channel → "Copy Channel ID"
ANALYSIS_CHANNEL_ID=1297596458337439754

# ✅ REQUIRED — The Discord channel ID for hourly trading advice
ADVICE_CHANNEL_ID=1216836991942135859

# 📸 OPTIONAL — Send screenshots with your posts (cloud-friendly)
# Leave blank to use the default 'screenshots' folder in your code.
SCREENSHOT_FOLDER=
